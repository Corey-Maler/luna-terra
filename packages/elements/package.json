{
  "name": "@lunaterra/elements",
  "version": "0.0.2",
  "description": "Reusable drawable elements for Luna-Terra scenes.",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepack": "pnpm build",
