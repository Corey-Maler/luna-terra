{
  "name": "@lunaterra/elements",
  "version": "0.0.3",
  "description": "Reusable drawable elements for Luna-Terra scenes.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Corey-Maler/luna-terra.git",
    "directory": "packages/elements"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:compile": "tsc -p tsconfig.lib.json",
    "build": "pnpm run clean && pnpm run build:compile",
    "prepack": "pnpm run build:compile",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lunaterra/core": "workspace:*",
    "@lunaterra/math": "workspace:*",
    "@lunaterra/color": "workspace:*",
    "tslib": "^2.3.0"
  }
}
