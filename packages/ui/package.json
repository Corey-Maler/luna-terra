{
  "name": "@lunaterra/ui",
  "version": "0.0.1",
  "description": "Canvas overlay UI components for Luna-Terra workflows.",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepack": "pnpm build",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lunaterra/core": "workspace:*",
    "@lunaterra/charts": "workspace:*",
    "@lunaterra/elements": "workspace:*",
    "@lunaterra/math": "workspace:*",
    "@lunaterra/tracing": "workspace:*",
    "tslib": "^2.3.0"
  }
}
