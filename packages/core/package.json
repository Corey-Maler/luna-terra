{
  "name": "@lunaterra/core",
  "version": "0.0.4",
  "description": "Core Luna-Terra canvas engine, renderer, and interaction primitives.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Corey-Maler/luna-terra.git",
    "directory": "packages/core"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:compile": "tsc -p tsconfig.lib.json",
    "build": "pnpm run clean && pnpm run build:compile",
    "prepack": "pnpm run build:compile",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "@lunaterra/color": "workspace:*",
    "@lunaterra/math": "workspace:*",
    "@lunaterra/tracing": "workspace:*"
  }
}
