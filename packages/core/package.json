{
  "name": "@lunaterra/core",
  "version": "0.0.1",
  "description": "Core Luna-Terra canvas engine, renderer, and interaction primitives.",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepack": "pnpm build",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "@lunaterra/color": "workspace:*",
    "@lunaterra/math": "workspace:*",
    "@lunaterra/tracing": "workspace:*"
  }
}
