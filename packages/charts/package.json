{
  "name": "@lunaterra/charts",
  "version": "0.0.5",
  "description": "Chart components and charting utilities for Luna-Terra.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Corey-Maler/luna-terra.git",
    "directory": "packages/charts"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:compile": "tsc -p tsconfig.lib.json",
    "build": "pnpm run clean && pnpm run build:compile",
    "prepack": "pnpm run build:compile",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lunaterra/core": "workspace:*",
    "@lunaterra/math": "workspace:*",
    "@lunaterra/color": "workspace:*",
    "@lunaterra/elements": "workspace:*",
    "d3-scale": "^4.0.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@types/d3-scale": "^4.0.8"
  }
}
